# LLM provider keys (set at least one)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
# OpenAI direct (https://platform.openai.com/api-keys).
OPENAI_API_KEY=
# OpenRouter brokers many backends behind a single OpenAI-compatible API
# (https://openrouter.ai/keys). Useful when you want to switch models without
# re-wiring the app.
OPENROUTER_API_KEY=

# Default provider: "anthropic", "google", "groq", "openai", or "openrouter"
AI_SCIENTIST_DEFAULT_PROVIDER=anthropic
AI_SCIENTIST_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AI_SCIENTIST_GOOGLE_MODEL=gemini-2.0-flash
AI_SCIENTIST_GROQ_MODEL=llama-3.3-70b-versatile
AI_SCIENTIST_OPENAI_MODEL=gpt-4o-mini
AI_SCIENTIST_OPENROUTER_MODEL=openai/gpt-4o-mini
AI_SCIENTIST_OPENROUTER_SITE_URL=http://localhost:3000
AI_SCIENTIST_OPENROUTER_APP_NAME=AI Scientist

# Embeddings (used for the vector store)
AI_SCIENTIST_EMBED_PROVIDER=google
AI_SCIENTIST_GOOGLE_EMBED_MODEL=gemini-embedding-001

# Storage paths (relative to backend/)
AI_SCIENTIST_DATA_DIR=./data
AI_SCIENTIST_CHROMA_DIR=./data/chroma
AI_SCIENTIST_DB_URL=sqlite:///./data/ai_scientist.db
AI_SCIENTIST_PDF_CACHE=./data/pdfs
AI_SCIENTIST_WORKSPACE=./data/workspaces

# Sandbox limits for the experiment runner
AI_SCIENTIST_SANDBOX_TIMEOUT_S=120
AI_SCIENTIST_SANDBOX_MAX_OUTPUT_BYTES=200000

# Optional: Semantic Scholar API key (higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Optional: Tavily web-search API key (https://app.tavily.com)
# When set, the pipeline also pulls live web results alongside arXiv/S2/OpenAlex.
TAVILY_API_KEY=

# CORS for the Next.js frontend
AI_SCIENTIST_CORS_ORIGINS=http://localhost:3000
